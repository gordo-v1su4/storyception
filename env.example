# ==========================================
# STORYCEPTION ENVIRONMENT CONFIGURATION
# ==========================================
# Copy this to .env.local

# ==========================================
# GOOGLE GEN AI — Vertex + ADC (default) is the ONLY mode that fully works in 2026.
# See GOOGLE_AUTH_AND_PIPELINE_NOTES_2026-05-14.md and lib/gemini-client.ts.
# ==========================================
#
# RECOMMENDED — Vertex + Application Default Credentials (ADC):
#   1. gcloud auth application-default login    (once per machine)
#   2. set the 3 vars below.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_GENAI_VERTEX_USE_GCP_PROJECT=1
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
#
# LEGACY — Vertex Express (API key + vertexai=true).
#   Most "AQ.*" account-bound keys are rejected by Vertex's PredictionService
#   with ACCESS_TOKEN_TYPE_UNSUPPORTED. Only use this if Google has explicitly
#   given you an Express-tier key that still works.
#   GOOGLE_CLOUD_API_KEY=AQ.xxx
#   GOOGLE_GENAI_VERTEX_EXPRESS=1   # force Express even with project hints
#
# LEGACY — AI Studio Developer API (generativelanguage.googleapis.com).
#   Useful for `AIza*` keys; not all 3.x preview models are exposed here.
#   GEMINI_API_KEY=AIzaXXXX
#   GOOGLE_GENAI_USE_VERTEXAI=false

# Gemini call timeout (ms). Default 45000 for beat/image, 90000 for story planning.
# GEMINI_TIMEOUT_MS=

# Initial story narrative model: `pro` (gemini-3.1-pro-preview) or `flash` (gemini-3-flash-preview).
# Pro is gated to very low quota right now (429 RESOURCE_EXHAUSTED). Default to flash
# until preview quota opens up.
STORY_WORKFLOW_NARRATIVE_MODEL=flash
STORY_BRANCH_NARRATIVE_MODEL=flash

# POST /api/branches/generate uses in-app Gemini by default. Set to 1 to use the n8n webhook.
# STORYCEPTION_BRANCH_USE_N8N=0

# Official SDK docs (naming is shifting from “Vertex AI” toward unified “Gemini Enterprise” / Gen AI):
# https://googleapis.github.io/js-genai/

# ==========================================
# N8N (optional — Storyception logic is in-app + NocoDB + RustFS)
# ==========================================
N8N_BASE_URL=https://n8n.v1su4.dev
# Get from n8n Settings > API
N8N_API_KEY=
# ==========================================
# NOCODB DATABASE
# ==========================================
NOCODB_BASE_URL=https://nocodb.v1su4.dev
NOCODB_API_TOKEN=
NOCODB_BASE_ID=

# Table Meta IDs — **required** for `STORYCEPTION_PERSISTENCE=nocodb` (or auto when probe succeeds).
# Create four tables per lib/storyception-schema.ts (snake_case columns). Copy each table id from the base Swagger:
# paths like /api/v3/data/{baseId}/{tableId}/records
#NOCODB_TABLE_SESSIONS=
#NOCODB_TABLE_BEATS=
#NOCODB_TABLE_BRANCHES=
#NOCODB_TABLE_KEYFRAMES=

# persistence: omit or `auto` — uses NocoDB v3 when token + base + all four table ids respond; else local JSON at .data/storyception-store.json
# Deleting `.data/storyception-store.json` resets local persistence (e.g. after schema/key renames).
# `reference_image_url`: inline `data:` images are not stored; use Long text for short https URLs in NocoDB.
# STORYCEPTION_MAX_REFERENCE_URL_LENGTH=50000  # optional max length for stored URL strings
# STORYCEPTION_PERSISTENCE=nocodb   # force NocoDB only (errors if tables missing)
# STORYCEPTION_PERSISTENCE=file     # force local file (good for serverless where disk is ephemeral)
# STORYCEPTION_LOCAL_DB_PATH=...    # optional override for JSON path

# Legacy: allow generate API to return 200 without saving if persistence throws (dev / STORYCEPTION_SKIP_NOCODB=1).
#STORYCEPTION_SKIP_NOCODB=1

# ==========================================
# RUSTFS / MEDIA API STORAGE
# ==========================================
# Shared upload/read API in front of RustFS
MEDIA_API_BASE_URL=https://media.v1su4.dev
MEDIA_API_TOKEN=
# Public-read bucket used by Storyception
STORYCEPTION_MEDIA_BUCKET=storyception
# Optional logical caller id for uploads
STORYCEPTION_MEDIA_USER_ID=storyception

# ==========================================
# N8N WEBHOOK PATHS (pre-configured)
# ==========================================
# These are example webhook paths — align automation with Gemini Developer API models in `lib/gemini-models.ts`.
# - /webhook/storyception-keyframes  (e.g. 9-keyframe flow)
# - /webhook/storyception-base-image (optional base image — prefer `gemini-3-pro-image-preview`)
# - /webhook/storyception-gemini-grid (3×3 grid)
# - /webhook/nocodb-image-trigger    (vision / analysis)

