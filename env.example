# ==========================================
# STORYCEPTION ENVIRONMENT CONFIGURATION
# ==========================================
# Copy this to .env.local

# ==========================================
# N8N ORCHESTRATION
# ==========================================
N8N_BASE_URL=https://n8n.v1su4.dev
# Get from n8n Settings > API
N8N_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
# Same API key works; the app also reads GOOGLE_GENAI_API_KEY and GEMINI_API_KEY (see lib/gemini-api-key.ts).
# GOOGLE_GENAI_API_KEY=

# ==========================================
# NOCODB DATABASE
# ==========================================
NOCODB_BASE_URL=https://nocodb.v1su4.dev
NOCODB_API_TOKEN=
NOCODB_BASE_ID=

# Table Meta IDs — **required** for `STORYCEPTION_PERSISTENCE=nocodb` (or auto when probe succeeds).
# Create four tables per lib/storyception-schema.ts (snake_case columns). Copy each table id from the base Swagger:
# paths like /api/v3/data/{baseId}/{tableId}/records
#NOCODB_TABLE_SESSIONS=
#NOCODB_TABLE_BEATS=
#NOCODB_TABLE_BRANCHES=
#NOCODB_TABLE_KEYFRAMES=

# persistence: omit or `auto` — uses NocoDB v3 when token + base + all four table ids respond; else local JSON at .data/storyception-store.json
# Deleting `.data/storyception-store.json` resets local persistence (e.g. after schema/key renames).
# `reference_image_url`: inline `data:` images are not stored; use Long text for short https URLs in NocoDB.
# STORYCEPTION_MAX_REFERENCE_URL_LENGTH=50000  # optional max length for stored URL strings
# STORYCEPTION_PERSISTENCE=nocodb   # force NocoDB only (errors if tables missing)
# STORYCEPTION_PERSISTENCE=file     # force local file (good for serverless where disk is ephemeral)
# STORYCEPTION_LOCAL_DB_PATH=...    # optional override for JSON path

# Legacy: allow generate API to return 200 without saving if persistence throws (dev / STORYCEPTION_SKIP_NOCODB=1).
#STORYCEPTION_SKIP_NOCODB=1

# ==========================================
# NEXTCLOUD STORAGE
# ==========================================
# WebDAV / API origin (not the login page path /l)
NEXTCLOUD_BASE_URL=https://cloud.v1su4.dev
NEXTCLOUD_USERNAME=admin
# Generate an App Password in Nextcloud: Settings > Security > Devices & sessions
# Leave empty for local `bun dev` only: uploads use inline data URIs instead of WebDAV.
NEXTCLOUD_APP_PASSWORD=
# Folder path for storing generated images
NEXTCLOUD_UPLOAD_PATH=/Storyception

# ==========================================
# N8N WEBHOOK PATHS (pre-configured)
# ==========================================
# These are the webhook endpoints created in N8N:
# - /webhook/storyception-keyframes  (Nano Banana 9-keyframe generation)
# - /webhook/storyception-base-image (Flux Pro 2 base image)
# - /webhook/storyception-gemini-grid (Gemini 3x3 grid)
# - /webhook/nocodb-image-trigger    (Vision analysis)

